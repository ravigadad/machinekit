#!/usr/bin/env bash
# machinekit — top-level dispatcher and the one public entry point. Routes
# <subcommand> to libexec/machinekit-<subcommand>.
#
# This is the sole pure-3.2 entry: for the real subcommands it resolves a bash that
# meets the version floor (installing Homebrew's bash if the running one is too old)
# and execs the impl under it, so the libexec impls are free to use modern bash.
# Keep this file 3.2-safe forever.

set -euo pipefail

# Resolve this script's real path through any PATH symlink (e.g.
# ~/.local/bin/machinekit) before deriving the framework dir — readlink without
# -f for macOS portability, looping to follow a chain of links.
machinekit_source="${BASH_SOURCE[0]}"
while [ -L "$machinekit_source" ]; do
  machinekit_link_dir="$(cd -P "$(dirname "$machinekit_source")" && pwd)"
  machinekit_source="$(readlink "$machinekit_source")"
  case "$machinekit_source" in
    /*) ;;
    *)  machinekit_source="$machinekit_link_dir/$machinekit_source" ;;
  esac
done
MACHINEKIT_DIR="$(cd -P "$(dirname "$machinekit_source")/.." && pwd)"

usage() {
  cat <<'EOF'
machinekit — keep your personal computing experience consistent across machines.

Usage: machinekit <subcommand> [args...]

Subcommands:
  apply       Apply a blueprint to this machine.
  generate    Scaffold a new blueprint repo from the template.
  secrets     Inspect the blueprint's age-encrypted secrets pool.

Run `machinekit <subcommand> --help` for subcommand-specific options.
EOF
}

subcommand="${1:-}"
case "$subcommand" in
  apply|generate|secrets)
    shift
    # shellcheck source=../lib/bootstrap/bash.sh
    source "$MACHINEKIT_DIR/lib/bootstrap/bash.sh"
    modern_bash="$(bootstrap::bash::ensure_modern_bash)"
    exec "$modern_bash" "$MACHINEKIT_DIR/libexec/machinekit-$subcommand" "$@"
    ;;
  -h|--help|help)
    usage; exit 0
    ;;
  -v|--version|version)
    cat "$MACHINEKIT_DIR/VERSION"
    exit 0
    ;;
  "")
    usage >&2; exit 1
    ;;
  *)
    printf 'machinekit: unknown subcommand: %s\n\n' "$subcommand" >&2
    usage >&2
    exit 1
    ;;
esac
