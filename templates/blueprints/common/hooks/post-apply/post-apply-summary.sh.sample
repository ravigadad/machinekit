#!/usr/bin/env bash
# Post-apply summary hook — logs what was just applied.
# Remove the .sample extension to activate: mv post-apply-summary.sh.sample post-apply-summary.sh
#
# Hooks in this directory run in alphabetical order after chezmoi, Brewfile,
# and mise have been applied. A non-zero exit fails the apply.

set -euo pipefail

# MACHINEKIT_SUPPORT is set by machinekit apply. Sourcing it gives you:
#   logging::*        output helpers (info, warn, error, success, step, fail)
#   input::is_dry_run / input::is_interactive   mode detection
#   context::get / context::set / context::get_array   resolved apply values
#   lifecycle::register_cleanup   register a function to run at script exit
# shellcheck disable=SC1090
source "$MACHINEKIT_SUPPORT"

# Always handle dry-run. Use input::dry_run to describe what the hook *would*
# do; then exit so no real side effects happen.
if input::is_dry_run; then
  input::dry_run "would print apply summary"
  exit 0
fi

logging::step "Apply summary"

# context::get returns 1 if a key is unset, so use || to provide a fallback.
git_name=$(config::get "module.git.user_name"  || printf "(not set)")
git_email=$(config::get "module.git.user_email" || printf "(not set)")
blueprints=$(context::get "blueprints.source" || printf "(unknown)")
os_family=$(context::get "os.family" || printf "(unknown)")
os_arch=$(context::get "os.arch"     || printf "(unknown)")

logging::info "Git identity : $git_name <$git_email>"
logging::info "Blueprints   : $blueprints"
logging::info "Platform     : $os_family/$os_arch"

# context::get_array emits one item per line; use a while-read loop to iterate.
if context::get_array "modules.active" >/dev/null 2>&1; then
  logging::info "Modules      :"
  while IFS= read -r module; do
    logging::info "  $module"
  done < <(context::get_array "modules.active")
fi

logging::success "Done."
