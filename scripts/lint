#!/usr/bin/env bash
# Run shellcheck across machinekit's bash files.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO_ROOT"

if ! command -v shellcheck >/dev/null 2>&1; then
  echo "shellcheck is not installed. Install it with: brew install shellcheck" >&2
  exit 1
fi

# Production code and shared test infra are linted strictly (default severity).
shellcheck \
  bin/* \
  lib/**/*.sh \
  scripts/* \
  tests/**/*.sh \
  tests/vm/cases/* \
  tests/vm/run \
  tests/test_helper.bash

# bats runs each @test in its own subshell, so SC2030/SC2031 ("modification in
# subshell might be lost") are inherent false positives in test files — the
# scoping is the point. SC2119 likewise fires on fixtures that intentionally
# call a logging helper with no args.
shellcheck --exclude=SC2030,SC2031,SC2119 \
  tests/**/*.bats
