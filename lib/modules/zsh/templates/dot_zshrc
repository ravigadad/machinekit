# ~/.zshrc — managed by machinekit.
# Standard shell environment is in machinekit's config dir
# (${XDG_CONFIG_HOME:-$HOME/.config}/machinekit/env.zsh, also managed).
# Personal customizations go in ~/.zshrc.local — not managed, never overwritten.

source "${XDG_CONFIG_HOME:-$HOME/.config}/machinekit/env.zsh"

[ -f "${HOME}/.zshrc.local" ] && source "${HOME}/.zshrc.local"
