[user]
    name  = {{ .config.module.git.user_name }}
    email = {{ .config.module.git.user_email }}

[init]
    defaultBranch = main

[push]
    autoSetupRemote = true

[rerere]
    enabled = true

[diff]
    algorithm = histogram

[merge]
    conflictstyle = zdiff3

[branch]
    sort = -committerdate
