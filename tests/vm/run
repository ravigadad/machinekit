#!/usr/bin/env bash
# VM end-to-end test runner for machinekit.
#
# Runs machinekit apply against fresh throwaway VMs — catches failures that
# only surface on a clean machine (missing dirs, sudo config, etc.) and that
# unit tests with stubbed collaborators cannot see.
#
# Not run in CI. Prerequisites are not auto-installed; they're too large and
# machine-specific (install once, reuse across runs):
#   tart      brew install tart
#   images    tart pull ghcr.io/cirruslabs/ubuntu:latest          (~20 GB)
#             tart pull ghcr.io/cirruslabs/macos-sequoia-vanilla:latest  (~50 GB)
#   sshpass   brew install hudochenkov/sshpass/sshpass  (macOS images only)
#
# Usage:
#   tests/vm/run                          all cases × all default images
#   tests/vm/run --image <image>          specific image (repeatable)
#   tests/vm/run --case apply-smoke       specific case
#   tests/vm/run --keep-vm                preserve VM after test (for debugging)
#
# All image/case combinations run in parallel. Step-level progress messages
# appear in real time, prefixed with [image/case]. Raw VM output (brew, tart,
# etc.) is buffered and shown only on failure.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
VM_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=lib/vm.sh
source "$VM_DIR/lib/vm.sh"

DEFAULT_IMAGES=(
  "ghcr.io/cirruslabs/ubuntu:latest"
  "ghcr.io/cirruslabs/macos-sequoia-vanilla:latest"
)
DEFAULT_CASES=(apply-smoke)

IMAGES=()
CASES=()
KEEP_VM=false

while [ $# -gt 0 ]; do
  case "$1" in
    --image)    IMAGES+=("$2");  shift 2 ;;
    --case)     CASES+=("$2");   shift 2 ;;
    --keep-vm)  KEEP_VM=true;    shift ;;
    -h|--help)
      grep '^#' "$0" | sed 's/^#[[:space:]]*//' | sed '/^!/d'
      exit 0
      ;;
    *) printf 'unknown option: %s\n' "$1" >&2; exit 1 ;;
  esac
done

[ "${#IMAGES[@]}" -eq 0 ] && IMAGES=("${DEFAULT_IMAGES[@]}")
[ "${#CASES[@]}" -eq 0 ]  && CASES=("${DEFAULT_CASES[@]}")

# ---------------------------------------------------------------------------
# Prerequisite checks
# ---------------------------------------------------------------------------

if ! command -v tart >/dev/null 2>&1; then
  printf 'error: tart not found. Install with: brew install tart\n' >&2
  exit 1
fi

_needs_sshpass=false
for _img in "${IMAGES[@]}"; do
  case "$_img" in *ubuntu*|*linux*|*debian*) ;; *) _needs_sshpass=true ;; esac
done
if [ "$_needs_sshpass" = true ] && ! command -v sshpass >/dev/null 2>&1; then
  printf 'error: sshpass required for macOS VM tests.\n' >&2
  printf '  brew install hudochenkov/sshpass/sshpass\n' >&2
  exit 1
fi

# ---------------------------------------------------------------------------
# Parallel run
# ---------------------------------------------------------------------------

_pids=()
_labels=()
_result_files=()
_log_files=()

_cleanup_all() {
  local pid
  for pid in "${_pids[@]+"${_pids[@]}"}"; do
    kill "$pid" 2>/dev/null || true
  done
  wait 2>/dev/null || true
  local f
  for f in \
    "${_result_files[@]+"${_result_files[@]}"}" \
    "${_log_files[@]+"${_log_files[@]}"}"; do
    rm -f "$f" 2>/dev/null || true
  done
}
trap '_cleanup_all' EXIT INT TERM

for image in "${IMAGES[@]}"; do
  for case_name in "${CASES[@]}"; do
    case_file="$VM_DIR/cases/$case_name"
    label="$image / $case_name"

    # Short label for the per-line prefix: strip registry prefix and tag.
    image_short="${image##*/}"
    image_short="${image_short%%:*}"
    prefix="${image_short}/${case_name}"

    if [ ! -f "$case_file" ]; then
      _vm_fail "$label — case file not found: $case_file"
      continue
    fi

    result_file=$(mktemp)
    log_file=$(mktemp)
    _labels+=("$label")
    _result_files+=("$result_file")
    _log_files+=("$log_file")

    vm_log "$label — starting"

    (
      # Each subshell manages its own VM — no shared state with siblings.
      VM_NAME=""
      VM_OS=""
      # Route raw VM command output (brew, tart exec, etc.) to the log file
      # only; shown on failure. Step messages go to both so they appear live.
      _VM_LOG="$log_file"

      # Override vm_log/vm_step to write to both the log (for failure dumps)
      # and the terminal (prefixed, so parallel runs stay attributable).
      vm_log()  {
        printf '\033[1;34m[vm] %s\033[0m\n' "$*" >> "$log_file"
        printf '[%s] \033[1;34m[vm] %s\033[0m\n' "$prefix" "$*"
      }
      vm_step() {
        printf '\033[0;36m  → %s\033[0m\n' "$*" >> "$log_file"
        printf '[%s] \033[0;36m→ %s\033[0m\n' "$prefix" "$*"
      }

      trap 'vm::stop 2>/dev/null || true' EXIT INT TERM

      _run_ok=false
      if vm::start "$image" "$REPO_ROOT"; then
        # shellcheck source=/dev/null
        if (source "$case_file" && scenario::run); then
          _run_ok=true
        fi
      fi

      if [ "$KEEP_VM" = true ] && [ -n "${VM_NAME:-}" ]; then
        printf '\nVM preserved: %s  (OS: %s)\n' "$VM_NAME" "$VM_OS"
        printf 'To exec into it:  tart exec %s -- bash\n' "$VM_NAME"
        printf 'To clean up:      tart stop %s && tart delete %s\n' "$VM_NAME" "$VM_NAME"
        VM_NAME=""  # prevent EXIT trap from stopping it
      fi

      if [ "$_run_ok" = true ]; then
        printf 'PASS\n' > "$result_file"
      else
        printf 'FAIL\n' > "$result_file"
      fi
    ) &
    _pids+=($!)
  done
done

# Wait for all runs to finish, then print the final summary.
wait || true

_pass=0
_fail=0

for i in "${!_pids[@]}"; do
  label="${_labels[$i]}"
  result=$(cat "${_result_files[$i]}" 2>/dev/null || printf 'FAIL')
  if [ "$result" = "PASS" ]; then
    _vm_ok "$label"
    _pass=$((_pass + 1))
  else
    _vm_fail "$label"
    _fail=$((_fail + 1))
    printf '\n--- output: %s ---\n' "$label"
    cat "${_log_files[$i]}"
    printf '--- end output ---\n\n'
  fi
  rm -f "${_result_files[$i]}" "${_log_files[$i]}"
done

printf '\n%d passed, %d failed\n' "$_pass" "$_fail"
[ "$_fail" -eq 0 ]
