#!/usr/bin/env bash
# machinekit secrets (impl) — inspect and populate the blueprint's age-encrypted
# secrets pool. Invoked by `machinekit secrets` under a bash that meets the version
# floor (bin/machinekit resolves one); not a public entry point. The guard below
# makes a direct invocation under an old bash fail cleanly instead of throwing a
# syntax error.
#
# This is the thin controller: it parses flags and dispatches. The orchestration
# and logic live in lib/machinekit/secrets/ (cli, render, put).

MACHINEKIT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=../lib/common/bash_floor.sh
source "$MACHINEKIT_DIR/lib/common/bash_floor.sh"
bash_floor::guard

set -euo pipefail

# shellcheck source=../lib/machinekit.sh
source "$MACHINEKIT_DIR/lib/machinekit.sh"

usage() {
  cat <<'EOF'
Usage: machinekit secrets [command] [flags]

Inspect the blueprint's secrets across their backends, and populate its
age-encrypted pool.

Commands:
  list                 List the secrets the active modules need, with each
                       one's resolved source (pool, secrets manager, or
                       missing). This is the default when no command is given.
  put [<name>]         Age-encrypt a value and place it as the <name> secret
                       in the pool (manager-backed secrets are populated in
                       the manager directly, not through here).
                       Read-only on git: it writes to a working tree; you commit.

`put` target (<name>):
                       Bare name → the .age file lands at the pool path
                                   `secrets list` shows for that name.
                       Absolute path → written as-is (an escape hatch).
                       Omitted   → interactive pick from the inventory.
                       Env: MACHINEKIT_SECRETS_PATH

`put` value (never an argument — keeps plaintext out of shell history):
                       --from-file, else piped stdin, else an interactive prompt.
      --from-file <path>                   Read the secret value from a file.

`put` options:
      --recipient <age-pubkey>             Encrypt to this recipient instead of
                                           the one derived from the installed key.
                                           Env: MACHINEKIT_SECRETS_RECIPIENT
      --blueprints-dir <path>              Working tree a relative target resolves
                                           against (default: a local blueprints
                                           source). Env: MACHINEKIT_SECRETS_BLUEPRINTS_DIR
      --overwrite                          Allow replacing an existing pool secret.
                                           Env: MACHINEKIT_SECRETS_OVERWRITE=1

Blueprint source:
      --blueprints-source <url-or-path>    URL or local path for the blueprints.
                                           Env: MACHINEKIT_BLUEPRINTS_SOURCE
      --blueprints-source-protocol <proto> Override the sniffed protocol (git, cp).
                                           Env: MACHINEKIT_BLUEPRINTS_SOURCE_PROTOCOL

Inputs:
      --machine-type <type>                Machine type label (selects modules).
                                           Env: MACHINEKIT_MACHINE_TYPE

Misc:
  -h, --help                               Show this message and exit.
  -v, --verbose                            Verbose debug output.
                                           Env: MACHINEKIT_VERBOSE=1
EOF
}

COMMAND="list"
OPT_TARGET=""
OPT_FROM_FILE=""

while [ $# -gt 0 ]; do
  case "$1" in
    list)                            COMMAND="list";                                        shift ;;
    put)                             COMMAND="put";                                         shift ;;
    --from-file)                     OPT_FROM_FILE="${2}";                                  shift 2 ;;
    --from-file=*)                   OPT_FROM_FILE="${1#*=}";                               shift ;;
    --recipient)                     export MACHINEKIT_SECRETS_RECIPIENT="${2}";            shift 2 ;;
    --recipient=*)                   export MACHINEKIT_SECRETS_RECIPIENT="${1#*=}";         shift ;;
    --blueprints-dir)                export MACHINEKIT_SECRETS_BLUEPRINTS_DIR="${2}";       shift 2 ;;
    --blueprints-dir=*)              export MACHINEKIT_SECRETS_BLUEPRINTS_DIR="${1#*=}";    shift ;;
    --overwrite)                     export MACHINEKIT_SECRETS_OVERWRITE=1;                 shift ;;
    --blueprints-source)             export MACHINEKIT_BLUEPRINTS_SOURCE="${2}";            shift 2 ;;
    --blueprints-source=*)           export MACHINEKIT_BLUEPRINTS_SOURCE="${1#*=}";         shift ;;
    --blueprints-source-protocol)    export MACHINEKIT_BLUEPRINTS_SOURCE_PROTOCOL="${2}";   shift 2 ;;
    --blueprints-source-protocol=*)  export MACHINEKIT_BLUEPRINTS_SOURCE_PROTOCOL="${1#*=}";shift ;;
    --machine-type)                  export MACHINEKIT_MACHINE_TYPE="${2}";                 shift 2 ;;
    --machine-type=*)                export MACHINEKIT_MACHINE_TYPE="${1#*=}";              shift ;;
    -v|--verbose)                    export MACHINEKIT_VERBOSE=1;                           shift ;;
    -h|--help)                       usage; exit 0 ;;
    --version)                       cat "$MACHINEKIT_DIR/VERSION"; exit 0 ;;
    --)                              shift; break ;;
    -*)                              lifecycle::fail "Unknown flag: $1 (try --help)" ;;
    *)                               # A bare argument is the put target path; anything
                                     # else (or a second positional) is an error.
                                     if [ "$COMMAND" = put ] && [ -z "$OPT_TARGET" ]; then
                                       OPT_TARGET="$1"; shift
                                     else
                                       lifecycle::fail "Unexpected argument: $1 (try --help)"
                                     fi ;;
  esac
done

main() {
  secrets::cli::dispatch "$COMMAND" "$OPT_TARGET" "$OPT_FROM_FILE"
}

[ "${BASH_SOURCE[0]}" != "$0" ] || main "$@"
