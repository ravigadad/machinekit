#!/usr/bin/env bash
# machinekit secrets (impl) — inspect the blueprint's age-encrypted secrets pool.
# Invoked by `machinekit secrets` under a bash that meets the version floor
# (bin/machinekit resolves one); not a public entry point. The guard below makes
# a direct invocation under an old bash fail cleanly instead of throwing a syntax
# error.
#
# Read-only: resolves inputs (fetch the blueprint, load config, compute the
# active module set) and reports which pool secrets the active modules need
# versus what the pool already holds. It never writes to the pool.

MACHINEKIT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=../lib/common/bash_floor.sh
source "$MACHINEKIT_DIR/lib/common/bash_floor.sh"
bash_floor::guard

set -euo pipefail

# shellcheck source=../lib/machinekit.sh
source "$MACHINEKIT_DIR/lib/machinekit.sh"

usage() {
  cat <<'EOF'
Usage: machinekit secrets [command] [flags]

Inspect the blueprint's age-encrypted secrets pool.

Commands:
  list        List the pool secrets the active modules need, with their status
              (required or generated) and whether each is already in the pool.
              This is the default when no command is given.

Blueprint source (required):
      --blueprints-source <url-or-path>    URL or local path for the blueprints.
                                           Env: MACHINEKIT_BLUEPRINTS_SOURCE
      --blueprints-source-protocol <proto> Override the sniffed protocol (git, cp).
                                           Env: MACHINEKIT_BLUEPRINTS_SOURCE_PROTOCOL

Inputs:
      --machine-type <type>                Machine type label (selects modules).
                                           Env: MACHINEKIT_MACHINE_TYPE

Misc:
  -h, --help                               Show this message and exit.
  -v, --verbose                            Verbose debug output.
                                           Env: MACHINEKIT_VERBOSE=1
EOF
}

COMMAND="list"

while [ $# -gt 0 ]; do
  case "$1" in
    list)                            COMMAND="list";                                        shift ;;
    --blueprints-source)             export MACHINEKIT_BLUEPRINTS_SOURCE="${2}";            shift 2 ;;
    --blueprints-source=*)           export MACHINEKIT_BLUEPRINTS_SOURCE="${1#*=}";         shift ;;
    --blueprints-source-protocol)    export MACHINEKIT_BLUEPRINTS_SOURCE_PROTOCOL="${2}";   shift 2 ;;
    --blueprints-source-protocol=*)  export MACHINEKIT_BLUEPRINTS_SOURCE_PROTOCOL="${1#*=}";shift ;;
    --machine-type)                  export MACHINEKIT_MACHINE_TYPE="${2}";                 shift 2 ;;
    --machine-type=*)                export MACHINEKIT_MACHINE_TYPE="${1#*=}";              shift ;;
    -v|--verbose)                    export MACHINEKIT_VERBOSE=1;                           shift ;;
    -h|--help)                       usage; exit 0 ;;
    --version)                       cat "$MACHINEKIT_DIR/VERSION"; exit 0 ;;
    --)                              shift; break ;;
    -*)                              lifecycle::fail "Unknown flag: $1 (try --help)" ;;
    *)                               lifecycle::fail "Unknown command: $1 (try --help)" ;;
  esac
done

# Resolve inputs read-only (no lock, no installs, no staging — none of which a
# listing needs), then render the pool inventory.
secrets::cli::list() {
  context::init_storage
  brew::bootstrap
  prerequisites::install
  context::seed_from_flags    # requires prerequisites (jq)
  context::load_user_config   # requires prerequisites (toml2json)
  input::detect_mode
  preflight::resolve_inputs
  secrets::cli::render
}

# The human view: a table of the secrets the active modules declare, then —
# separately — any pool secrets no active module recognizes.
secrets::cli::render() {
  local rows orphans
  rows="$(secrets::inventory)"
  orphans="$(secrets::orphans)"

  if [ -z "$rows" ] && [ -z "$orphans" ]; then
    logging::info "No pool secrets are needed or present for the active modules."
    return 0
  fi

  [ -n "$rows" ] && secrets::cli::_render_table "$rows"
  [ -n "$orphans" ] && secrets::cli::_render_orphans "$orphans"
  return 0
}

# A blank-prefixed table with bold headers, hand-aligned (column -t can't be used
# — the per-row ANSI codes would throw off its width math). Each row is colored by
# how it stands: green when already in the pool, yellow when absent but machinekit
# will generate it, red when it is a blocker (absent, required, not generated).
secrets::cli::_render_table() {
  local rows="$1" path required can_be_generated state in_pool req_col gen_col color line
  # Decide color here, where stdout is the command's real stdout — never inside a
  # $() (there fd 1 is the capture pipe, so [ -t 1 ] would always be false).
  local bold="" reset="" green="" yellow="" red=""
  if secrets::cli::_color_enabled; then
    bold=$'\033[1m'; reset=$'\033[0m'
    green=$'\033[32m'; yellow=$'\033[33m'; red=$'\033[31m'
  fi

  local secret_width=6 # len("SECRET")
  while IFS=$'\t' read -r path _; do
    [ "${#path}" -gt "$secret_width" ] && secret_width="${#path}"
  done <<< "$rows"

  printf '\n'
  printf -v line '%-*s  %-7s  %-8s  %-19s' \
    "$secret_width" SECRET "IN POOL" REQUIRED "GENERATE IF MISSING"
  printf '%s%s%s\n' "$bold" "$line" "$reset"

  while IFS=$'\t' read -r path required can_be_generated state; do
    [ -n "$path" ] || continue
    if [ "$state" = provided ]; then in_pool=yes; else in_pool=no; fi
    if [ "$required" = true ]; then req_col=yes; else req_col=no; fi
    if [ "$can_be_generated" = true ]; then gen_col=yes; else gen_col=no; fi
    # Green once it's in the pool; otherwise yellow if machinekit will generate it,
    # red if it's a required blocker, and uncolored if it's merely optional.
    if [ "$state" = provided ]; then
      color="$green"
    elif [ "$can_be_generated" = true ]; then
      color="$yellow"
    elif [ "$required" = true ]; then
      color="$red"
    else
      color=""
    fi
    printf -v line '%-*s  %-7s  %-8s  %-19s' \
      "$secret_width" "$path" "$in_pool" "$req_col" "$gen_col"
    printf '%s%s%s\n' "$color" "$line" "$reset"
  done <<< "$rows"
}

# The strays: pool files no active module claims. Not a table — a flagged list,
# since the actionable thing is to check each name for a typo or staleness.
secrets::cli::_render_orphans() {
  local orphans="$1" path yellow="" reset=""
  if secrets::cli::_color_enabled; then yellow=$'\033[33m'; reset=$'\033[0m'; fi
  printf '\n%sUnrecognized secrets in the pool — not used by any active module.%s\n' "$yellow" "$reset"
  printf 'Check each for a typo or a stale entry:\n'
  while IFS= read -r path; do
    [ -n "$path" ] || continue
    printf '  %s\n' "$path"
  done <<< "$orphans"
}

# True when stdout is a color-capable TTY (so piping the table into a pager or
# grep stays clean). Honors NO_COLOR. Must be called from the function that writes
# to stdout, not via $() — a command substitution's fd 1 is a pipe, not the TTY.
secrets::cli::_color_enabled() {
  [ -t 1 ] && [ -z "${NO_COLOR:-}" ]
}

main() {
  case "$COMMAND" in
    list) secrets::cli::list ;;
    *)    lifecycle::fail "Unknown command: $COMMAND" ;;
  esac
}

[ "${BASH_SOURCE[0]}" != "$0" ] || main "$@"
